{
  "kind": "collectionType",
  "collectionName": "planos",
  "info": {
    "singularName": "plano",
    "pluralName": "planos",
    "displayName": "Plano"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Titulo": {
      "type": "string",
      "required": true
    },
    "Exercicios": {
      "type": "text"
    },
    "clientes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::cliente.cliente",
      "mappedBy": "plano"
    },
    "Preco": {
      "type": "decimal"
    },
    "Descricao": {
      "type": "text"
    },
    "users": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "plano"
    },
    "ImagemPlano": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
