{
  "kind": "collectionType",
  "collectionName": "aulas",
  "info": {
    "singularName": "aula",
    "pluralName": "aulas",
    "displayName": "Aula"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Nome": {
      "type": "string",
      "required": true
    },
    "Horario": {
      "type": "string",
      "required": true
    },
    "Dia": {
      "type": "enumeration",
      "enum": ["seg", "ter", "qua", "qui", "sex", "sab", "dom"],
      "required": true
    },
    "Duracao": {
      "type": "string",
      "default": "45'"
    },
    "Periodo": {
      "type": "enumeration",
      "enum": ["manha", "tarde"],
      "required": true
    },
    "Cor": {
      "type": "string",
      "default": "orange"
    },
    "treinador": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::treinador.treinador",
      "inversedBy": "aulas"
    },
    "clientes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cliente.cliente",
      "inversedBy": "aulas"
    }
  }
}
