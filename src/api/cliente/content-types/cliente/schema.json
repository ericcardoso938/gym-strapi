{
  "kind": "collectionType",
  "collectionName": "clientes",
  "info": {
    "singularName": "cliente",
    "pluralName": "clientes",
    "displayName": "Cliente"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Nome": {
      "type": "string",
      "minLength": 3,
      "required": true,
      "unique": false,
      "regex": "^[a-zA-ZÀ-ÿ\\s]+$"
    },
    "Objetivo": {
      "type": "string",
      "required": true
    },
    "plano": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::plano.plano",
      "inversedBy": "clientes"
    },
    "aulas": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::aula.aula",
      "mappedBy": "clientes"
    },
    "dataInicio": {
      "type": "date",
      "required": true
    },
    "Foto": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
