{
  "kind": "collectionType",
  "collectionName": "items",
  "info": {
    "singularName": "item",
    "pluralName": "items",
    "displayName": "Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Disponivel": {
      "type": "boolean"
    },
    "Titulo": {
      "type": "string"
    },
    "Descricao": {
      "type": "string"
    },
    "Foto": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Tipo": {
      "type": "enumeration",
      "enum": [
        "Hamburguer",
        "Frito",
        "Bebida"
      ]
    },
    "Pedidos": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::pedido.pedido",
      "mappedBy": "Itens"
    }
  }
}
